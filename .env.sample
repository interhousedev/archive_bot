# * * * MONGODB * * *
# REQUIRED
MONGO_USER=mongo
# REQUIRED — change for security
MONGO_PASSWORD=changeme
# REQUIRED
MONGO_DB_NAME=archive_bot
# Auth source — keep as-is if using default mongo user
MONGO_OPTIONS=?authSource=admin
# Host(s) — use 127.0.0.1:27017 for local dev, ihd-mongo:27017 in prod compose
MONGO_HOSTS=127.0.0.1:27017
# MONGO_URI is constructed by scripts:
#   mongodb://${MONGO_USER}:${MONGO_PASSWORD}@${MONGO_HOSTS}/${MONGO_DB_NAME}${MONGO_OPTIONS}
# Set it directly if not using scripts (e.g. in prod compose via env_file override)
# MONGO_URI=mongodb://mongo:changeme@127.0.0.1:27017/archive_bot?authSource=admin

# * * * TELEGRAM BOT * * *
# REQUIRED for --telegram-bot
BOTAPI_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
# REQUIRED — Telegram ID of the admin (receives error reports, can use /create_event)
ADMIN_ID=123456789
# Local Bot API server URL — enables large file uploads (up to 2 GB)
# Leave empty to use official Telegram servers (20 MB limit)
# When using docker-compose: BOTAPI_SERVER_URL=http://telegram-bot-api:8081
BOTAPI_SERVER_URL=

# REQUIRED when using local Bot API server (get from https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Path where local Bot API server stores files (used for direct disk reads + cleanup).
# In Docker (prod): keep default /var/lib/telegram-bot-api (same bind mount path).
# On host (dev, bot not in Docker): set to ./data/botapi
BOTAPI_LOCAL_FILES_PATH=/var/lib/telegram-bot-api

# * * * EMIS VERIFICATION * * *
# Base URL — leave default unless EMIS changes their API
EMIS_BASE_URL=https://emis.edu.uz/api/v1/
# Institution ID to verify against — 10815 = IHD Tashkent
EMIS_INSTITUTION_ID=10815

# * * * S3 STORAGE (Cloupard or any S3-compatible) * * *
# REQUIRED
S3_ENDPOINT_URL=https://s3.cloupard.uz
# REQUIRED
S3_ACCESS_KEY=your_access_key
# REQUIRED
S3_SECRET_KEY=your_secret_key
# REQUIRED — bucket name
S3_BUCKET_NAME=archive-ihd
# REQUIRED — public base URL for serving images (no trailing slash)
S3_BASE_URL=https://cdn.cloupard.uz/archive-ihd

# * * * WEB (FastAPI gallery) * * *
# REQUIRED for --web — public URL of this web server (used as WebApp button link in bot)
WEBAPP_BASE_URL=https://archive.iht.uz
# Host and port for uvicorn (defaults shown)
WEB_HOST=0.0.0.0
WEB_PORT=8000
